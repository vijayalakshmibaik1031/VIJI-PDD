{
  "name": "facilitydesk-appium-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Appium + WebdriverIO E2E tests for FacilityDesk Android (Capacitor)",
  "scripts": {
    "test": "node run-tests.js",
    "tests:appium": "node run-tests.js",
    "test:wdio": "npx wdio run ./wdio.conf.js",
    "test:allure": "npx wdio run ./wdio.conf.js && npx allure generate allure-results --clean -o allure-report",
    "report:allure": "npx allure open allure-report",
    "report:generate": "npx allure generate allure-results --clean -o allure-report",
    "preflight": "node -e \"require('./helpers/preflight').runPreflight().forEach(c=>console.log((c.ok?'OK':'FAIL')+' '+c.label+': '+c.detail))\"",
    "generate:cases": "node scripts/generate-test-cases.js",
    "verify": "node -e \"const {buildTestCases}=require('./test-cases'); console.log('Ready:', buildTestCases().length, 'cases')\""
  },
  "dependencies": {
    "docx": "^9.7.1",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^8.43.0",
    "@wdio/appium-service": "^8.43.0",
    "@wdio/cli": "^8.43.0",
    "@wdio/local-runner": "^8.43.0",
    "@wdio/mocha-framework": "^8.43.0",
    "@wdio/spec-reporter": "^8.43.0",
    "allure-commandline": "^2.42.1",
    "appium": "^3.5.0",
    "appium-uiautomator2-driver": "^7.6.1",
    "chai": "^4.3.7"
  }
}
